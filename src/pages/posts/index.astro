---
/**
 * 文章列表（posts 集合全部条目：tech、weekly 等）
 */
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { getAllBlogLike, ArticleTime, PostUtils } from "@/utils/postUtils";

export const pageSlug = "posts";
export const pageTitle = `文章 | ${SITE.title}`;

const sorted = PostUtils.sort(await getAllBlogLike());
---

<Layout
  title={pageTitle}
  description="全部文章与周报，按最近更新排序。"
>
  <section aria-labelledby="posts-page-heading">
    <section aria-label="文章列表">
      <ol id="posts-list">
        {
          sorted.map(entry => {
            const date = ArticleTime.getDisplay(
              entry.data.date,
              entry.data.updated,
              entry.data.timezone,
              "absolute"
            );
            const description = (
              entry.data.description?.trim() ||
              PostUtils.getDescription(entry.body ?? "")
            ).trim();
            const href = PostUtils.getPath(
              entry.id,
              entry.filePath,
              true,
              entry.data.date,
              entry.data.timezone,
              entry.data.slug,
              entry.collection
            );

            return (
              <li>
                <article>
                  <p>
                    <time datetime={date.iso} title={date.titleAttr}>
                      {date.display}
                    </time>
                  </p>
                  <h2>
                    <a href={href}>{entry.data.title}</a>
                  </h2>
                  {description && <p>{description}</p>}
                </article>
              </li>
            );
          })
        }
      </ol>
    </section>
  </section>
</Layout>

<style>
  #posts-page-heading {
    margin: 0 0 0.5rem;
    font-size: 1.875rem;
    font-weight: 600;
    letter-spacing: -0.025em;
  }

  #posts-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #posts-list li > article {
    display: flex;
    flex-direction: column;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card-background);
    transition:
      border-color 0.18s ease,
      background-color 0.18s ease,
      transform 0.18s ease;
  }

  #posts-list li > article:hover {
    border-color: color-mix(in srgb, var(--accent) 34%, var(--border));
    background: var(--card-background-hover);
    transform: translateY(-1px);
  }

  #posts-list li > article > p:first-of-type {
    margin: 0 0 0.55rem;
    color: var(--text-secondary);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  #posts-list time {
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  #posts-list h2 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.42;
  }

  #posts-list h2 a {
    color: var(--text-primary);
    text-decoration: none;
  }

  #posts-list h2 a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  #posts-list li > article > h2 + p {
    display: -webkit-box;
    margin: 0.45rem 0 0;
    overflow: hidden;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.62;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  @media (max-width: 768px) {
    #posts-list li > article {
      padding: 0.85rem 0.9rem;
    }

    #posts-list h2 {
      font-size: 0.9375rem;
      font-weight: 600;
      line-height: 1.38;
    }
  }
</style>
