---
/**
 * 博客列表（content/tech 长文，不含 weekly/）
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { ArticleTime, PostUtils, isWeeklyPost } from "@/utils/postUtils";

export const pageSlug = "posts";
export const pageTitle = `博客 | ${SITE.title}`;

const sorted = PostUtils.sort(await getCollection("posts")).filter(
  entry => !isWeeklyPost(entry)
);
---

<Layout
  title={pageTitle}
  description="技术、生活等发布在博客目录下的长文，按最近更新排序。"
>
  <section class="posts-page" aria-labelledby="posts-page-heading">
    <h1 id="posts-page-heading" class="posts-page__title">博客</h1>
    <section class="home-feed" aria-label="博客列表">
      <ol class="home-feed-list">
        {
          sorted.map(entry => {
            const date = ArticleTime.getDisplay(
              entry.data.date,
              entry.data.updated,
              entry.data.timezone,
              "absolute"
            );
            const description = (
              entry.data.description?.trim() ||
              PostUtils.getDescription(entry.body ?? "")
            ).trim();
            const href = PostUtils.getPath(
              entry.id,
              entry.filePath,
              true,
              entry.data.date,
              entry.data.timezone,
              entry.data.slug,
              entry.collection
            );

            return (
              <li class="home-feed-item">
                <article class="home-feed-card">
                  <div class="home-feed-meta">
                    <time datetime={date.iso} title={date.titleAttr}>
                      {date.display}
                    </time>
                  </div>
                  <h2>
                    <a href={href}>{entry.data.title}</a>
                  </h2>
                  {description && <p>{description}</p>}
                </article>
              </li>
            );
          })
        }
      </ol>
    </section>
  </section>
</Layout>

<style>
  .posts-page__title {
    margin: 0 0 0.5rem;
    font-size: 1.875rem;
    font-weight: 600;
    letter-spacing: -0.025em;
  }
</style>
