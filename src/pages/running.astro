---
/**
 * 跑步统计页
 *
 * @fileoverview 展示来自 public/data/running.json 的跑步记录：周期统计、12 个月贡献日历、活动列表（构建时一次输出）、详情弹窗。弹窗 HTML 由 src/utils/running-modal-content.ts 生成。
 */
import Layout from "../layouts/Layout.astro";
import { SITE } from "@/config";

export const pageSlug = "running";
export const pageTitle = `跑步 | ${SITE.title}`;
export const pageDescription = SITE.description;

// 加载跑步数据
import runningJson from "../../public/data/running.json";

const data = runningJson;
const allRuns = data.runs.map(run => ({
  ...run,
  durationShort: formatDuration(run.duration ?? 0),
}));

// 转换时长格式（秒 -> "1h16m", "41m"）
function formatDuration(seconds: number): string {
  if (seconds <= 0) return "0m";
  const minutes = Math.round(seconds / 60);
  const hours = Math.floor(minutes / 60);
  const mins = minutes % 60;
  if (hours > 0 && mins > 0) return `${hours}h${mins}m`;
  if (hours > 0) return `${hours}h`;
  return `${mins}m`;
}

// 格式化配速（秒/km -> "7'58""）
function formatPace(secPerKm: number): string {
  if (!secPerKm || secPerKm <= 0) return "--";
  return `${Math.floor(secPerKm / 60)}'${Math.floor(secPerKm % 60)
    .toString()
    .padStart(2, "0")}"`;
}

// 准备日历数据 - 展示最近12个月，从每个月1号开始
const today = new Date();
const currentYear = today.getFullYear();
const currentMonth = today.getMonth();

// 计算起始日期：12个月前的1号（使用UTC避免时区问题）
const startYear = currentMonth >= 11 ? currentYear : currentYear - 1;
const startMonth = currentMonth >= 11 ? currentMonth - 11 : currentMonth + 1;
const startOfRange = new Date(Date.UTC(startYear, startMonth, 1));

// 计算结束日期：本月的最后一天
const endOfRange = new Date(Date.UTC(currentYear, currentMonth + 1, 0));

// 生成日期映射 - 同一天的多条记录合并
interface DaySummary {
  distance: number;
  duration: number;
  runs: typeof data.runs;
}

const dateMap = new Map<string, DaySummary>();
data.runs.forEach(run => {
  const dateStr = run.startTime.split(" ")[0];
  const existing = dateMap.get(dateStr);
  if (!existing) {
    dateMap.set(dateStr, {
      distance: run.distance,
      duration: run.duration ?? 0,
      runs: [run],
    });
  } else {
    existing.distance += run.distance;
    existing.duration += run.duration ?? 0;
    existing.runs.push(run);
  }
});

// 获取颜色强度
function getIntensity(distance: number): number {
  if (!distance) return 0;
  if (distance < 3) return 1;
  if (distance < 5) return 2;
  if (distance < 10) return 3;
  if (distance < 15) return 4;
  return 5;
}

// 生成日历网格数据 - 从起始月1号之前的周一开始（使用UTC）
const calendarStart = new Date(startOfRange);
const dayOfWeek = calendarStart.getUTCDay();
const daysToSubtract = dayOfWeek === 0 ? 6 : dayOfWeek - 1;
calendarStart.setUTCDate(calendarStart.getUTCDate() - daysToSubtract);

interface DayData {
  dateStr: string;
  isInRange: boolean;
  intensity: number;
  title: string;
}

interface WeekData {
  days: DayData[];
}

const weeks: WeekData[] = [];
// 生成足够的周数来覆盖整个范围
const totalDays =
  Math.ceil(
    (endOfRange.getTime() - calendarStart.getTime()) / (1000 * 60 * 60 * 24)
  ) + 7;
const totalWeeks = Math.ceil(totalDays / 7);

for (let w = 0; w < totalWeeks; w++) {
  const weekDays: DayData[] = [];
  for (let d = 0; d < 7; d++) {
    const idx = w * 7 + d;
    const currentDate = new Date(calendarStart);
    currentDate.setUTCDate(calendarStart.getUTCDate() + idx);
    const dateStr = currentDate.toISOString().split("T")[0];
    const run = dateMap.get(dateStr);
    const isInRange = currentDate >= startOfRange && currentDate <= endOfRange;
    const intensity = getIntensity(run?.distance || 0);
    const title = run
      ? `${dateStr}: ${run.distance}km, ${run.duration}${run.runs.length > 1 ? ` (${run.runs.length}次)` : ""}`
      : dateStr;

    weekDays.push({
      dateStr,
      isInRange,
      intensity,
      title,
    });
  }
  weeks.push({ days: weekDays });
}

// 获取月份标签 - 每个月1号所在的周
const months: { label: string; weekIndex: number }[] = [];
for (let m = 0; m < 12; m++) {
  const monthDate = new Date(Date.UTC(startYear, startMonth + m, 1));
  const monthLabel = `${monthDate.getUTCMonth() + 1}月`;

  // 找到该月1号所在的周
  const daysSinceStart = Math.floor(
    (monthDate.getTime() - calendarStart.getTime()) / (1000 * 60 * 60 * 24)
  );
  const weekIndex = Math.floor(daysSinceStart / 7);

  if (weekIndex >= 0 && weekIndex < weeks.length) {
    months.push({ label: monthLabel, weekIndex });
  }
}

// 统计数据
const stats = data.stats;

// 周期标签映射
const periodLabels: Record<string, string> = {
  yesterday: "昨日",
  today: "今日",
  week: "本周",
  month: "本月",
  year: "今年",
  total: "总计",
};
const periodOrder: string[] = Object.keys(periodLabels);
const statsRecord = stats as Record<
  string,
  (typeof data.stats)[keyof typeof data.stats]
>;
const defaultPeriod: string = stats.today
  ? "today"
  : (periodOrder.find(p => statsRecord[p]) ?? "today");

// 心率区间标签（7 区间模型）
const hrZoneLabels: Record<number, string> = {
  0: "",
  1: "Z1 恢复",
  2: "Z2 有氧",
  3: "Z3 节奏",
  4: "Z4 阈值下",
  5: "Z5 阈值上",
  6: "Z6 有氧能力",
  7: "Z7 无氧",
};

// 心率区间颜色（7 区间模型，基于 Keep App 配色）
const hrZoneColors: Record<number, string> = {
  0: "var(--text-secondary)",
  1: "#5FBFAD", // Z1 恢复 - 青绿色
  2: "#4CAF50", // Z2 有氧 - 绿色
  3: "#FFC947", // Z3 节奏 - 黄色
  4: "#FF9F47", // Z4 阈值下 - 橙色
  5: "#FF5C7C", // Z5 阈值上 - 粉红色
  6: "#9061F5", // Z6 有氧能力 - 紫色
  7: "#8B8599", // Z7 无氧 - 深紫灰
};
---

<Layout title={pageTitle} description={pageDescription}>
  <h1>跑步</h1>
  <div class="running-page">
    {
      !data || !data.stats ? (
        <p>暂无数据。</p>
      ) : (
        <div>
          {/* 周期统计卡片 - Tab 切换 */}
          {stats && Object.keys(stats).length > 0 && (
            <div id="periodStats">
              <div class="period-stats-card">
                {/* Tab 导航 */}
                <div class="period-tab-nav" id="periodTabNav">
                  {periodOrder.map(period => {
                    const pStats = statsRecord[period];
                    if (!pStats) return null;
                    const isActive = period === defaultPeriod;
                    return (
                      <button
                        class={`period-tab-btn ${isActive ? "active" : ""}`}
                        data-period={period}
                      >
                        {periodLabels[period]}
                      </button>
                    );
                  })}
                </div>

                {/* Tab 内容 */}
                <div class="period-tab-content">
                  {periodOrder.map(period => {
                    const pStats = statsRecord[period];
                    if (!pStats) return null;
                    const isActive = period === defaultPeriod;
                    return (
                      <div
                        class={`period-panel ${isActive ? "active" : ""}`}
                        data-panel={period}
                      >
                        <div class="period-panel-grid">
                          <div class="period-panel-stat">
                            <span class="period-panel-value highlight">
                              {pStats.totalActivities}
                            </span>
                            <span class="period-panel-label">跑步次数</span>
                          </div>
                          <div class="period-panel-stat">
                            <span class="period-panel-value highlight">
                              {pStats.totalDistance}
                            </span>
                            <span class="period-panel-label">距离 (公里)</span>
                          </div>
                          <div class="period-panel-stat">
                            <span class="period-panel-value">
                              {(pStats.totalDuration ?? 0).toFixed(1)}
                            </span>
                            <span class="period-panel-label">
                              总时长 (小时)
                            </span>
                          </div>
                          <div class="period-panel-stat">
                            <span class="period-panel-value">
                              {pStats.longestDistance?.toFixed(2) ?? "--"}
                            </span>
                            <span class="period-panel-label">最长距离</span>
                          </div>
                          <div class="period-panel-stat">
                            <span class="period-panel-value">
                              {formatPace(pStats.averagePace)}
                            </span>
                            <span class="period-panel-label">平均配速</span>
                          </div>
                          <div class="period-panel-stat">
                            <span class="period-panel-value">
                              {pStats.averageHeartRate ?? "--"}
                            </span>
                            <span class="period-panel-label">BPM</span>
                          </div>
                          <div class="period-panel-stat">
                            <span class="period-panel-value">
                              {pStats.averageVdot?.toFixed(1) ?? "--"}
                            </span>
                            <span class="period-panel-label">平均 VDOT</span>
                          </div>
                          <div class="period-panel-stat">
                            <span class="period-panel-value">
                              {pStats.bestVdot?.toFixed(1) ?? "--"}
                            </span>
                            <span class="period-panel-label">最佳 VDOT</span>
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          )}

          <div class="contribution-graph">
            <div class="calendar-wrapper">
              <div class="calendar">
                <div class="month-labels">
                  {months.map(m => (
                    <span
                      class="month-label"
                      style={`left: ${(m.weekIndex / weeks.length) * 100}%`}
                    >
                      {m.label}
                    </span>
                  ))}
                </div>
                <div class="weeks">
                  {weeks.map(week => (
                    <div class="week">
                      {week.days.map(day => (
                        <div
                          class={`day ${day.isInRange ? "" : "out-of-range"} intensity-${day.intensity}`}
                          data-tooltip={day.title}
                        />
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <h2>最近活动</h2>
          {data.runs.length === 0 ? (
            <p class="run-list-empty">暂无跑步记录</p>
          ) : (
            <>
              <div
                class="run-list"
                id="runList"
                data-hr-zone-labels={JSON.stringify(hrZoneLabels)}
                data-hr-zone-colors={JSON.stringify(hrZoneColors)}
              >
                {allRuns.map((run, index) => (
                  <div
                    class="run-card"
                    data-run-index={index}
                    data-run={JSON.stringify(run)}
                  >
                    <div class="run-main">
                      <div class="run-header">
                        <time class="run-date">
                          {run.startTime.split(" ")[0]}
                        </time>
                        {run.heartRateZone > 0 && (
                          <span
                            class="hr-zone-badge"
                            style={`background-color: ${hrZoneColors[run.heartRateZone]}20; color: ${hrZoneColors[run.heartRateZone]}; border: 1px solid ${hrZoneColors[run.heartRateZone]}40;`}
                          >
                            {hrZoneLabels[run.heartRateZone]}
                          </span>
                        )}
                        {run.weatherInfo && (
                          <span class="run-weather" title="天气">
                            {run.weatherInfo}
                          </span>
                        )}
                      </div>
                      <span class="run-type">
                        {run.name || "户外跑步"}
                        {run.region && (
                          <span class="run-route"> · {run.region}</span>
                        )}
                      </span>
                    </div>
                    <div class="run-stats">
                      <div class="stat">
                        <span class="stat-value">{run.distance}</span>
                        <span class="stat-label">km</span>
                      </div>
                      <div class="stat">
                        <span class="stat-value">{run.durationShort}</span>
                        <span class="stat-label">时长</span>
                      </div>
                      <div class="stat">
                        <span class="stat-value">
                          {formatPace(run.averagePace ?? 0)}
                        </span>
                        <span class="stat-label">配速</span>
                      </div>
                      <div class="stat">
                        <span class="stat-value">
                          {run.averageHeartRate > 0
                            ? Math.round(run.averageHeartRate)
                            : "-"}
                        </span>
                        <span class="stat-label">BPM</span>
                      </div>
                      <div class="stat vdot-stat">
                        <span class="stat-value">{run.vDOT ?? "-"}</span>
                        <span class="stat-label">VDOT</span>
                      </div>
                      <div class="stat load-stat">
                        <span class="stat-value">{run.trainingLoadScore}</span>
                        <span class="stat-label">负荷</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </>
          )}
        </div>
      )
    }
  </div>

  <!-- 运动详情弹窗 -->
  <div class="run-detail-modal" id="runDetailModal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
      <button class="modal-close" id="modalClose">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="18" y1="6" x2="6" y2="18"></line><line
            x1="6"
            y1="6"
            x2="18"
            y2="18"></line></svg
        >
      </button>
      <div class="modal-body" id="modalBody">
        <!-- 动态内容 -->
      </div>
    </div>
  </div>
</Layout>

<script>
  import {
    buildRunDetailModalHtml,
    type RunningRecord,
  } from "@/utils/running-modal-content";

  const runList = document.getElementById("runList");
  const hrZoneLabels = runList
    ? JSON.parse(runList.getAttribute("data-hr-zone-labels") || "{}")
    : {};
  const hrZoneColors = runList
    ? JSON.parse(runList.getAttribute("data-hr-zone-colors") || "{}")
    : {};

  const periodTabNav = document.getElementById("periodTabNav");
  if (periodTabNav) {
    periodTabNav.addEventListener("click", e => {
      const target =
        e.target instanceof Element
          ? e.target.closest(".period-tab-btn")
          : null;
      if (!target) return;

      const period = target.getAttribute("data-period");
      if (!period) return;

      const tabButtons = periodTabNav.querySelectorAll(".period-tab-btn");
      tabButtons.forEach(btn => {
        btn.classList.toggle("active", btn === target);
      });

      const periodPanels = document.querySelectorAll(".period-panel");
      periodPanels.forEach(panel => {
        const panelPeriod = panel.getAttribute("data-panel");
        panel.classList.toggle("active", panelPeriod === period);
      });
    });
  }

  // 详情弹窗功能
  const modal = document.getElementById("runDetailModal");
  const modalBody = document.getElementById("modalBody");
  const modalClose = document.getElementById("modalClose");
  const modalOverlay = modal?.querySelector(".modal-overlay");

  function openModal(run: RunningRecord) {
    if (!modal || !modalBody) return;

    modalBody.innerHTML = buildRunDetailModalHtml(run, {
      hrZoneLabels,
      hrZoneColors,
    });

    modal.classList.add("active");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.remove("active");
    document.body.style.overflow = "";
  }

  const runListEl = document.getElementById("runList");
  if (runListEl) {
    runListEl.addEventListener("click", function (e) {
      const card =
        e.target instanceof Element ? e.target.closest(".run-card") : null;
      if (!card) return;
      const runData = card.getAttribute("data-run");
      if (runData) openModal(JSON.parse(runData) as RunningRecord);
    });
  }

  // 关闭弹窗事件
  modalClose?.addEventListener("click", closeModal);
  modalOverlay?.addEventListener("click", closeModal);

  // ESC键关闭弹窗
  document.addEventListener("keydown", e => {
    if (e.key === "Escape") {
      closeModal();
    }
  });
</script>
