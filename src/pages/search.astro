---
/**
 * 搜索页
 */
import Layout from "@/layouts/Layout.astro";

export const pageSlug = "search";
export const pageTitle = "搜索";
export const pageDescription = "搜索所有文章";
---

<Layout title={pageTitle} description={pageDescription} robots="noindex,follow">
  <section aria-labelledby="search-page-heading">
    <div id="search">
      <div>
        <input
          type="search"
          id="search-input"
          placeholder="输入关键词搜索..."
          autocomplete="off"
        />
        <button id="search-button" type="button">搜索</button>
      </div>
      <div id="search-results"></div>
    </div>
  </section>
</Layout>

<style>
  #search-page-heading {
    margin: 0 0 0.5rem;
    font-size: 1.875rem;
    font-weight: 600;
    letter-spacing: -0.025em;
  }

  @media (max-width: 768px) {
    #search-page-heading {
      font-size: 1.5rem;
    }
  }

  #search > div:first-of-type {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  #search-input {
    width: 100%;
    min-width: 0;
  }

  #search-results {
    margin-top: 1.5rem;
  }

  #search-results > p {
    margin: 0 0 0.75rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  #search-results mark {
    padding: 0 0.12em;
    border-radius: 0.2em;
    background: var(--accent-surface);
    color: var(--accent);
  }

  @media (min-width: 640px) {
    #search > div:first-of-type {
      flex-direction: row;
      align-items: stretch;
    }

    #search-input {
      flex: 1;
    }

    #search-button {
      flex-shrink: 0;
    }
  }
</style>

<style is:global>
  #search-results ol {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #search-results ol li > article {
    display: flex;
    flex-direction: column;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card-background);
  }

  #search-results ol li > article:hover {
    border-color: color-mix(in srgb, var(--accent) 34%, var(--border));
    background: var(--card-background-hover);
  }

  #search-results h2 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.42;
  }

  #search-results h2 a {
    color: var(--text-primary);
    text-decoration: none;
  }

  #search-results h2 a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  #search-results ol li > article > p {
    margin: 0.45rem 0 0;
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.625;
  }
</style>

<script is:inline>
  async function initSearchPage() {
    const searchInput = document.getElementById("search-input");
    const searchButton = document.getElementById("search-button");
    const resultsContainer = document.getElementById("search-results");
    if (!searchInput || !searchButton || !resultsContainer) return;
    if (searchInput.dataset.bound === "1") return;

    searchInput.dataset.bound = "1";

    const initialQuery =
      new URLSearchParams(window.location.search).get("q")?.trim() || "";

    let pagefind;
    let loadingPagefind = false;
    let pagefindReady = false;

    function escapeHtml(text) {
      return String(text)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    function messageHtml(text) {
      return `<p>${escapeHtml(text)}</p>`;
    }

    async function ensurePagefind() {
      if (pagefindReady || loadingPagefind) return pagefindReady;

      loadingPagefind = true;
      searchInput.placeholder = "正在加载搜索功能...";

      try {
        pagefind = await import("/pagefind/pagefind.js");
        await pagefind.init();
        pagefindReady = true;
        searchInput.placeholder = "搜索文章标题、内容...";
        searchInput.disabled = false;
        return true;
      } catch {
        resultsContainer.innerHTML =
          messageHtml("搜索功能加载失败，请刷新页面重试");
        searchInput.placeholder = "搜索功能加载失败";
        return false;
      } finally {
        loadingPagefind = false;
      }
    }

    async function performSearch() {
      const query = searchInput.value.trim();
      if (!query) {
        resultsContainer.innerHTML = "";
        return;
      }

      const ready = await ensurePagefind();
      if (!ready) return;

      resultsContainer.innerHTML = messageHtml("搜索中...");

      try {
        const search = await pagefind.search(query);

        if (search.results.length === 0) {
          resultsContainer.innerHTML = messageHtml(
            "未找到「" + query + "」的相关结果"
          );
          return;
        }

        let html =
          "<p>找到 " + search.results.length + " 个结果</p>";
        html += "<ol>";

        for (const result of search.results.slice(0, 10)) {
          const data = await result.data();
          html += "<li><article>";
          html +=
            '<h2><a href="' +
            escapeHtml(data.url) +
            '">' +
            escapeHtml(data.meta.title || "无标题") +
            "</a></h2>";
          html += "<p>" + data.excerpt + "</p>";
          html += "</article></li>";
        }

        html += "</ol>";

        if (search.results.length > 10) {
          html +=
            "<p>还有 " +
            (search.results.length - 10) +
            " 个结果...</p>";
        }

        resultsContainer.innerHTML = html;
      } catch {
        resultsContainer.innerHTML = messageHtml("搜索出错，请重试");
      }
    }

    async function warmupSearch() {
      await ensurePagefind();
    }

    searchInput.disabled = false;
    searchInput.placeholder = "输入关键词搜索...";
    searchButton.addEventListener("click", performSearch);
    searchInput.addEventListener("keypress", e => {
      if (e.key === "Enter") performSearch();
    });
    searchInput.addEventListener("focus", warmupSearch, { once: true });
    searchInput.addEventListener("pointerdown", warmupSearch, { once: true });
    searchButton.addEventListener("pointerdown", warmupSearch, { once: true });

    if (initialQuery) {
      searchInput.value = initialQuery;
      await performSearch();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initSearchPage, {
      once: true,
    });
  } else {
    initSearchPage();
  }
  document.addEventListener("astro:page-load", initSearchPage);
</script>
