---
/**
 * 404 错误页
 */
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";

export const pageSlug = "404";
export const pageTitle = `404 Not Found | ${SITE.title}`;
export const pageDescription = SITE.description;

const notFoundImage = "https://cos.lhasa.icu/StylePictures/404.webp";
const notFoundTitle = "404，您访问的页面不存在～";
---

<Layout title={pageTitle} description={pageDescription} robots="noindex,follow">
  <section aria-labelledby="not-found-heading">
    <img
      src={notFoundImage}
      alt="404 Not Found"
      width="448"
      height="252"
      loading="eager"
      decoding="async"
    />
    <p id="not-found-heading">{notFoundTitle}</p>
    <a href="/">回到首页</a>
  </section>
</Layout>

<style>
  section[aria-labelledby="not-found-heading"] {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1rem;
    text-align: center;
  }

  section[aria-labelledby="not-found-heading"] img {
    width: 100%;
    max-width: 28rem;
    height: auto;
    margin: 0 auto 1.5rem;
    border-radius: var(--radius);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.08);
  }

  #not-found-heading {
    margin: 0 0 1.5rem;
    font-size: 1.125rem;
    color: var(--text-secondary);
  }

  section[aria-labelledby="not-found-heading"] > a {
    font-size: 1rem;
    font-weight: 500;
  }
</style>
