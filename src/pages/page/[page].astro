---
import FeedPage from "@/layouts/FeedPage.astro";
import {
  getFeedPaginationStaticPaths,
  type HomeFeedItem,
} from "@/utils/postUtils";

export const getStaticPaths = getFeedPaginationStaticPaths;

interface Props {
  items: HomeFeedItem[];
  nextPage: number | null;
  page: number;
}

const { items, nextPage, page } = Astro.props;
---

<FeedPage items={items} nextPage={nextPage} page={page} robots="noindex" />
