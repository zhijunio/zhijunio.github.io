---
import HomeFeed from "@/components/HomeFeed.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { getHomeFeedPage } from "@/utils/postUtils";

const { items, nextPage } = await getHomeFeedPage(1);
---

<Layout description={SITE.description}>
  <HomeFeed items={items} nextPage={nextPage} />
</Layout>
