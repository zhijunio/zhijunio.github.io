---
import FeedPage from "@/layouts/FeedPage.astro";
import { getAllHomeFeedItems, paginateHomeFeedItems } from "@/utils/postUtils";

const allFeedItems = await getAllHomeFeedItems();
const { items, nextPage } = paginateHomeFeedItems(allFeedItems, 1);
---

<FeedPage items={items} nextPage={nextPage} />
