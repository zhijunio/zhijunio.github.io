---
import HomeFeed from "@/components/HomeFeed.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { getAllHomeFeedItems, paginateHomeFeedItems } from "@/utils/postUtils";

const { items, nextPage } = paginateHomeFeedItems(
  await getAllHomeFeedItems(),
  1
);
---

<Layout description={SITE.description}>
  <HomeFeed items={items} nextPage={nextPage} />
</Layout>
