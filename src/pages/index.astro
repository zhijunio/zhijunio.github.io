---
/**
 * 首页
 *
 * @fileoverview 最近博客、周报混排卡片列表。
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { PostUtils } from "@/utils/postUtils";
import { SITE } from "@/config";
import { ArticleTime } from "@/utils/articleTime";

/** 与 /og/index.png 一致 */
export const pageSlug = "index";
export const pageTitle = SITE.title;
export const pageDescription = SITE.description;

const limit = SITE.postPerIndex * 2;

function isBriefPost(entry: { id: string; filePath?: string }): boolean {
  return (
    entry.id.startsWith("briefs/") ||
    entry.filePath?.replace(/\\/g, "/").includes("/posts/briefs/") === true
  );
}

const feedItems = PostUtils.sort(await getCollection("posts"))
  .map(entry => ({
    entry,
    kind: isBriefPost(entry) ? "周报" : "博客",
    kindClass: isBriefPost(entry)
      ? "home-feed-kind--brief"
      : "home-feed-kind--post",
  }))
  .sort(
    (a, b) =>
      Math.floor(
        new Date(b.entry.data.updated ?? b.entry.data.date).getTime() / 1000
      ) -
      Math.floor(
        new Date(a.entry.data.updated ?? a.entry.data.date).getTime() / 1000
      )
  )
  .slice(0, limit);
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="home-feed" aria-label="最近记录">
    <ol class="home-feed-list" aria-label="最近记录列表">
      {
        feedItems.map(({ entry, kind, kindClass }) => {
          const date = ArticleTime.getDisplay(
            entry.data.date,
            entry.data.updated,
            entry.data.timezone,
            "absolute"
          );
          const description = (
            entry.data.description?.trim() ||
            PostUtils.getDescription(entry.body ?? "")
          ).trim();
          const href = PostUtils.getPath(
            entry.id,
            entry.filePath,
            true,
            entry.data.date,
            entry.data.timezone,
            entry.data.slug,
            entry.collection
          );

          return (
            <li class="home-feed-item">
              <article class="home-feed-card">
                <div class="home-feed-meta">
                  <time datetime={date.iso} title={date.titleAttr}>
                    {date.display}
                  </time>
                  <span class:list={["home-feed-kind", kindClass]}>{kind}</span>
                </div>
                <h2>
                  <a href={href}>{entry.data.title}</a>
                </h2>
                {description && <p>{description}</p>}
              </article>
            </li>
          );
        })
      }
    </ol>
  </section>
</Layout>
