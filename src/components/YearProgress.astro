---
/** 顶栏下年度进度：即时填充 + 悬停显示百分比 */
---

<div
  id="year-progress"
  role="progressbar"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-live="polite"
  aria-label="本年度已过时间比例"
>
  <div id="year-progress-track">
    <div class="year-progress-rail">
      <div id="year-progress-fill"></div>
    </div>
    <span id="year-progress-label"></span>
  </div>
</div>

<style>
  #year-progress {
    width: 100%;
    max-width: var(--site-chrome-width);
    margin: 0.2rem auto 0;
    padding: 0 1.5rem 0.3rem;
  }

  #year-progress-track {
    position: relative;
    min-height: 14px;
    display: flex;
    align-items: center;
    cursor: default;
  }

  .year-progress-rail {
    height: 2px;
    width: 100%;
    border-radius: 999px;
    background: color-mix(in srgb, var(--border) 88%, var(--text-secondary));
    overflow: hidden;
  }

  #year-progress-fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: var(--accent);
  }

  #year-progress-label {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    opacity: 0;
    pointer-events: none;
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1;
    color: var(--accent);
    white-space: nowrap;
    padding: 0 0.15rem;
    background: color-mix(in srgb, var(--background) 88%, transparent);
    border-radius: 3px;
    transition: opacity 0.15s ease;
  }

  #year-progress-label:global(.year-progress-visible) {
    opacity: 1;
  }

  @media (max-width: 768px) {
    #year-progress {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>

<script>
  function yearProgress(): number {
    const now = new Date();
    const start = new Date(now.getFullYear(), 0, 1);
    const end = new Date(now.getFullYear() + 1, 0, 1);
    return Math.min(
      1,
      Math.max(
        0,
        (now.getTime() - start.getTime()) / (end.getTime() - start.getTime())
      )
    );
  }

  function initYearProgress(): void {
    const root = document.getElementById("year-progress");
    const track = document.getElementById("year-progress-track");
    const fill = document.getElementById("year-progress-fill");
    const label = document.getElementById("year-progress-label");
    if (!root || !track || !fill || !label || track.dataset.bound) return;

    const pct = yearProgress();
    const text = (pct * 100).toFixed(1) + "%";
    fill.style.width = text;
    label.textContent = text;
    root.setAttribute("title", text);
    root.setAttribute("aria-valuenow", String(Math.round(pct * 100)));

    const placeLabel = () => {
      const cw = track.offsetWidth;
      const lw = label.offsetWidth || 0;
      label.style.left = Math.min(cw * pct + 3, Math.max(0, cw - lw)) + "px";
    };
    placeLabel();

    track.addEventListener("mouseenter", () => {
      placeLabel();
      label.classList.add("year-progress-visible");
    });
    track.addEventListener("mouseleave", () => {
      label.classList.remove("year-progress-visible");
    });

    track.dataset.bound = "1";
  }

  initYearProgress();
</script>
