---
import { SITE } from "@/config";
import YearProgress from "./YearProgress.astro";

const navLinks = [
  { href: "/", text: "首页" },
  { href: "/about", text: "关于" },
];

const { pathname } = Astro.url;

function isActiveNavLink(href: string): boolean {
  return href === "/"
    ? pathname === "/"
    : pathname === href || pathname.startsWith(href + "/");
}
---

<header>
  <nav>
    <a href="/">{SITE.title}</a>
    <ul>
      {
        navLinks.map(link => (
          <li>
            <a
              href={link.href}
              {...(isActiveNavLink(link.href)
                ? { "aria-current": "page" as const }
                : {})}
            >
              {link.text}
            </a>
          </li>
        ))
      }
    </ul>
    <a href="/search" aria-label="搜索">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </a>
    {
      SITE.lightAndDarkMode && (
        <button id="theme-toggle" type="button" aria-label="切换主题">
          <svg
            class="sun-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="5" />
            <line x1="12" y1="1" x2="12" y2="3" />
            <line x1="12" y1="21" x2="12" y2="23" />
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
            <line x1="1" y1="12" x2="3" y2="12" />
            <line x1="21" y1="12" x2="23" y2="12" />
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
          </svg>
          <svg
            class="moon-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      )
    }
  </nav>
  {SITE.showYearProgress && <YearProgress />}
</header>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--site-chrome-width);
    margin: 0 auto;
    padding: 0.35rem 1.5rem 0;
    gap: 1rem;
  }

  nav > a:first-of-type {
    font-weight: 700;
    font-size: clamp(0.9rem, 2.5vw, 1rem);
    line-height: 1.25;
    color: var(--text-primary);
    text-decoration: none;
  }

  nav > a:first-of-type:hover,
  nav > a:first-of-type:focus-visible {
    color: var(--accent);
    text-decoration: none;
  }

  nav > ul {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.1rem 0.7rem;
    list-style: none;
    margin: 0 0 0 auto;
    padding: 0;
  }

  nav > ul a {
    color: var(--text-secondary);
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
  }

  nav > ul a:hover,
  nav > ul a[aria-current="page"] {
    color: var(--accent);
  }

  nav > ul a[aria-current="page"] {
    font-weight: 600;
  }

  nav > a[href="/search"],
  #theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem;
    color: var(--text-secondary);
    border-radius: 6px;
  }

  nav > a[href="/search"]:hover,
  #theme-toggle:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  #theme-toggle {
    border: none;
    background: transparent;
  }

  :global([data-theme="light"]) .moon-icon,
  :global([data-theme="dark"]) .sun-icon {
    display: none;
  }

  @media (max-width: 768px) {
    nav {
      padding-left: 1rem;
      padding-right: 1rem;
      gap: 0.75rem;
    }
  }

  @media (max-width: 640px) {
    nav {
      align-items: flex-start;
      flex-direction: column;
    }

    nav > ul {
      width: 100%;
      margin-left: 0;
      gap: 0.65rem;
      overflow-x: auto;
      scrollbar-width: none;
    }

    nav > ul::-webkit-scrollbar {
      display: none;
    }
  }
</style>

<script>
  const themeToggle = document.getElementById("theme-toggle");
  if (themeToggle?.dataset.bound === "1") {
    // 避免脚本重复执行时重复绑定事件
  } else if (themeToggle) {
    themeToggle.dataset.bound = "1";

    function updateThemeToggleLabel() {
      if (!themeToggle) return;
      const currentTheme =
        document.documentElement.getAttribute("data-theme") || "light";
      themeToggle.setAttribute(
        "aria-label",
        currentTheme === "dark" ? "切换到浅色模式" : "切换到深色模式"
      );
    }

    function toggleTheme() {
      const themeManager = (
        window as Window & {
          __theme?: { toggleTheme?: () => string };
        }
      ).__theme;

      if (themeManager?.toggleTheme) {
        themeManager.toggleTheme();
        return;
      }

      const html = document.documentElement;
      const currentTheme = html.getAttribute("data-theme") || "light";
      const newTheme = currentTheme === "light" ? "dark" : "light";
      html.setAttribute("data-theme", newTheme);
      localStorage.setItem("theme", newTheme);
      updateThemeToggleLabel();
    }

    updateThemeToggleLabel();
    themeToggle.addEventListener("click", toggleTheme);

    themeToggle.addEventListener("keydown", e => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        toggleTheme();
      }
    });

    if (
      (window as Window & { _themeToggleLabelHandler?: () => void })
        ._themeToggleLabelHandler
    ) {
      window.removeEventListener(
        "themechange",
        (window as Window & { _themeToggleLabelHandler?: () => void })
          ._themeToggleLabelHandler as EventListener
      );
    }

    (
      window as Window & { _themeToggleLabelHandler?: () => void }
    )._themeToggleLabelHandler = updateThemeToggleLabel;
    window.addEventListener("themechange", updateThemeToggleLabel);
  }
</script>
