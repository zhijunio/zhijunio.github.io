---
import { SITE } from "@/config";
import YearProgress from "./YearProgress.astro";
import { siteImageHref } from "@/utils/blogImages";

const logoSrc = SITE.logo?.trim() ? siteImageHref(SITE.logo.trim()) : "";
const pathname = Astro.url.pathname.replace(/\.html?$/, "") || "/";
const isAboutPage = pathname === "/about" || pathname.startsWith("/about/");
---

<header class="site-header">
  <nav aria-label="站点导航">
    <a href="/" class="site-brand">
      {
        logoSrc && (
          <img
            class="site-logo"
            src={logoSrc}
            alt=""
            width="22"
            height="22"
            decoding="async"
            fetchpriority="high"
          />
        )
      }
      <span class="site-title">{SITE.title}</span>
    </a>
    <ul class="nav-links">
      <li>
        <a
          href="/about"
          {...isAboutPage ? { "aria-current": "page" as const } : {}}
        >
          关于
        </a>
      </li>
    </ul>
  </nav>
  <YearProgress />
</header>
