---
import "@/styles/feed.css";
import { SITE } from "@/config";
import type { HomeFeedItem } from "@/utils/postUtils";

interface Props {
  items: HomeFeedItem[];
  nextPage?: number | null;
}

const { items, nextPage = null } = Astro.props;
---

<section aria-label="文章列表">
  <ol id="home-feed-list">
    {
      items.map(item => (
        <li>
          <article>
            <p>
              <time datetime={item.dateIso}>{item.dateDisplay}</time>
            </p>
            <p class="home-feed-title">
              <a href={item.href}>{item.title}</a>
            </p>
            {item.description ? (
              <p class="home-feed-desc">{item.description}</p>
            ) : null}
          </article>
        </li>
      ))
    }
  </ol>
</section>

<template id="home-feed-item-template">
  <li>
    <article>
      <p>
        <time datetime=""></time>
      </p>
      <p class="home-feed-title">
        <a href=""></a>
      </p>
      <p class="home-feed-desc" hidden></p>
    </article>
  </li>
</template>

{
  nextPage !== null && (
    <>
      <div
        id="home-feed-sentinel"
        data-next-page={nextPage}
        aria-hidden="true"
      />
      <p id="home-feed-status" class="home-feed-status" hidden />
      <script>
        import { initHomeFeedInfiniteScroll } from "@/utils/homeFeedScroll";
        initHomeFeedInfiniteScroll();
      </script>
    </>
  )
}
