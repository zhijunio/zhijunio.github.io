---
import type { HomeFeedItem } from "@/utils/postUtils";

interface Props {
  items: HomeFeedItem[];
  nextPage?: number | null;
  /** 分页页码（≥2）；首页不传 */
  page?: number;
}

const { items, nextPage = null, page } = Astro.props;
const showPager = page !== undefined && page >= 2;
const prevHref = page === 2 ? "/" : page ? `/page/${page - 1}` : null;
---

<section aria-label="最近记录">
  {
    showPager && (
      <nav class="home-feed-pager" aria-label="分页">
        <a href="/">首页</a>
        {prevHref && <a href={prevHref}>上一页</a>}
      </nav>
    )
  }
  <ol id="home-feed-list" aria-label="最近记录列表">
    {
      items.map(item => (
        <li>
          <article>
            <p>
              <time datetime={item.dateIso}>{item.dateDisplay}</time>
            </p>
            <h2>
              <a href={item.href}>{item.title}</a>
            </h2>
            {item.description ? (
              <p class="home-feed-desc">{item.description}</p>
            ) : null}
          </article>
        </li>
      ))
    }
  </ol>
  {
    nextPage !== null && (
      <p class="home-feed-more-wrap">
        <a class="home-feed-more" href={`/page/${nextPage}`}>
          查看更多 …
        </a>
      </p>
    )
  }
</section>

<style is:global>
  .home-feed-pager {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    margin: 0 0 1rem;
    font-size: 0.875rem;
  }

  #home-feed-list {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #home-feed-list li > article {
    display: flex;
    min-height: 100%;
    min-width: 0;
    flex-direction: column;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card-background);
    transition:
      border-color 0.18s ease,
      background-color 0.18s ease,
      transform 0.18s ease;
  }

  #home-feed-list li > article:hover {
    border-color: color-mix(in srgb, var(--accent) 34%, var(--border));
    background: var(--card-background-hover);
    transform: translateY(-1px);
  }

  #home-feed-list li > article > p:first-of-type {
    margin: 0 0 0.55rem;
    color: var(--text-secondary);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  #home-feed-list time {
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  #home-feed-list h2 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.42;
  }

  #home-feed-list h2 a {
    color: var(--text-primary);
    text-decoration: none;
  }

  #home-feed-list h2 a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  #home-feed-list .home-feed-desc {
    margin: 0.45rem 0 0;
    color: var(--text-secondary);
    font-size: 0.8125rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  .home-feed-more-wrap {
    margin: 1.25rem 0 0;
    text-align: center;
  }

  .home-feed-more {
    display: inline-block;
    padding: 0.35rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card-background);
    color: var(--text-secondary);
    font-size: 0.875rem;
    text-decoration: none;
    transition:
      border-color 0.18s ease,
      color 0.18s ease,
      background-color 0.18s ease;
  }

  .home-feed-more:hover {
    border-color: color-mix(in srgb, var(--accent) 34%, var(--border));
    color: var(--accent);
    background: var(--card-background-hover);
  }

  @media (max-width: 768px) {
    #home-feed-list {
      gap: 0.75rem;
    }

    #home-feed-list li > article {
      padding: 0.85rem 0.9rem;
    }

    #home-feed-list li > article > p:first-of-type {
      margin-bottom: 0.5rem;
    }

    #home-feed-list h2 {
      font-size: 0.9375rem;
      font-weight: 600;
      line-height: 1.38;
    }
  }
</style>
