---
/**
 * 页脚组件（极简）
 */
import { SITE } from "@/config";
import SocialIcon from "@/components/SocialIcon.astro";

export interface Props {
  /** 是否显示社交链接 */
  showSocial?: boolean;
}

const currentYear = new Date().getFullYear();
const { showSocial = true } = Astro.props;

const socialLinks = SITE.socialLinks ?? [];
const hasSocial = showSocial && socialLinks.length > 0;

function normalizeSocialHref(url: string): string {
  if (url.startsWith("mailto:") || url.startsWith("http")) return url;
  if (url.includes("@")) return `mailto:${url}`;
  return url;
}
---

<footer class="footer">
  <div class="footer-content">
    <hr class="footer-hr" aria-hidden="true" />
    <div class="footer-row">
      <div class="footer-start">
        <span class="copyright">© {currentYear} {SITE.author}</span>
        {
          SITE.icp && (
            <a
              class="footer-icp"
              href="https://beian.miit.gov.cn/"
              target="_blank"
              rel="noopener noreferrer"
            >
              {SITE.icp}
            </a>
          )
        }
      </div>
      {
        hasSocial && (
          <div class="social-links">
            {socialLinks.map(link => {
              const href = normalizeSocialHref(link.url);
              const isExternal = href.startsWith("http");
              return (
                <a
                  href={href}
                  target={isExternal ? "_blank" : undefined}
                  rel={isExternal ? "noopener noreferrer" : undefined}
                  aria-label={link.name}
                >
                  <SocialIcon name={link.icon} width={16} height={16} />
                </a>
              );
            })}
          </div>
        )
      }
    </div>
  </div>
</footer>

<style is:global>
  .footer-content {
    max-width: var(--site-chrome-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem 1.25rem;
  }

  .footer-hr {
    margin: 0 0 0.85rem;
    border: 0;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .footer-content {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }

  .footer-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.75rem;
    min-height: 1.5rem;
  }

  .footer-start {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  .copyright {
    flex: 0 0 auto;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .footer-icp {
    flex: 0 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
  }

  .footer-icp:hover {
    color: var(--accent);
  }

  .social-links {
    display: flex;
    flex: 0 0 auto;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-left: auto;
  }

  .social-links a {
    color: var(--text-secondary);
    display: inline-flex;
    flex-shrink: 0;
  }

  .social-links a:hover {
    color: var(--accent);
  }
</style>
