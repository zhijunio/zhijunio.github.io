---
/**
 * 页脚组件（极简）
 */
import { SITE } from "@/config";
import SocialIcon from "@/components/SocialIcon.astro";

export interface Props {
  /** 是否显示社交链接 */
  showSocial?: boolean;
}

const currentYear = new Date().getFullYear();
const { showSocial = true } = Astro.props;

const socialLinks = SITE.socialLinks ?? [];
const hasSocial = showSocial && socialLinks.length > 0;

function normalizeSocialHref(url: string): string {
  if (url.startsWith("mailto:") || url.startsWith("http")) return url;
  if (url.includes("@")) return `mailto:${url}`;
  return url;
}
---

<footer>
  <hr aria-hidden="true" />
  <div>
    <div>
      <span>© {currentYear} {SITE.author}</span>
      {
        SITE.icp && (
          <a
            href="https://beian.miit.gov.cn/"
            target="_blank"
            rel="noopener noreferrer"
          >
            {SITE.icp}
          </a>
        )
      }
    </div>
    {
      hasSocial && (
        <div>
          {socialLinks.map(link => {
            const href = normalizeSocialHref(link.url);
            const isExternal = href.startsWith("http");
            return (
              <a
                href={href}
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
                aria-label={link.name}
              >
                <SocialIcon name={link.icon} />
              </a>
            );
          })}
        </div>
      )
    }
  </div>
</footer>

<style>
  footer {
    max-width: var(--site-chrome-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
  }

  footer > hr {
    margin: 0 0 0.85rem;
    border: 0;
    border-top: 1px solid var(--border);
  }

  footer > div {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.75rem;
    min-height: 1.5rem;
    font-size: inherit;
    line-height: inherit;
    color: var(--text-secondary);
  }

  footer > div > div:first-child {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  footer > div > div:first-child > span {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  footer > div > div:first-child > a {
    flex: 0 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: inherit;
    text-decoration: none;
  }

  footer > div > div:first-child > a:hover {
    color: var(--accent);
  }

  footer > div > div + div {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-left: auto;
  }

  footer > div > div + div a {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    min-height: 2.25rem;
    padding: 0.35rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 6px;
  }

  footer > div > div + div a:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  @media (max-width: 768px) {
    footer {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>
