---
/** 为文章内 Shiki 代码块（pre.astro-code）添加复制按钮 */
---

<script is:inline>
  function getCodeText(pre) {
    return (pre.textContent || "").replace(/\n$/, "");
  }

  async function copyText(text) {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.setAttribute("readonly", "");
      ta.style.cssText = "position:fixed;left:-9999px;top:0";
      document.body.appendChild(ta);
      ta.select();
      const ok = document.execCommand("copy");
      document.body.removeChild(ta);
      return ok;
    }
  }

  function initCodeCopyButtons() {
    const blocks = document.querySelectorAll(
      "#article .post-content pre.astro-code"
    );
    blocks.forEach(pre => {
      if (pre.closest(".code-block-wrap")) return;

      const wrap = document.createElement("div");
      wrap.className = "code-block-wrap";
      pre.parentNode.insertBefore(wrap, pre);
      wrap.appendChild(pre);

      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "code-copy-btn";
      btn.setAttribute("aria-label", "复制代码");
      btn.dataset.labelDefault = "复制";
      btn.dataset.labelDone = "已复制";
      btn.dataset.labelFail = "复制失败";
      btn.textContent = btn.dataset.labelDefault;

      const lang = pre.getAttribute("data-language");
      if (lang) btn.setAttribute("data-lang", lang);

      btn.addEventListener("click", async () => {
        const text = getCodeText(pre);
        if (!text) return;
        const ok = await copyText(text);
        if (!ok) {
          btn.textContent = btn.dataset.labelFail;
          btn.classList.add("is-copy-failed");
          window.setTimeout(() => {
            btn.textContent = btn.dataset.labelDefault;
            btn.classList.remove("is-copy-failed");
          }, 1600);
          return;
        }
        btn.textContent = btn.dataset.labelDone;
        btn.classList.add("is-copied");
        btn.classList.remove("is-copy-failed");
        window.setTimeout(() => {
          btn.textContent = btn.dataset.labelDefault;
          btn.classList.remove("is-copied");
        }, 1600);
      });

      wrap.appendChild(btn);
    });
  }

  function scheduleInit() {
    initCodeCopyButtons();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleInit, {
      once: true,
    });
  } else {
    scheduleInit();
  }
</script>

<style is:global>
  #article .code-block-wrap {
    position: relative;
    margin: 1.25rem 0;
  }

  #article .code-block-wrap > pre.astro-code {
    margin: 0;
  }

  #article .code-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 2;
    margin: 0;
    padding: 0.2rem 0.55rem;
    border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
    border-radius: 6px;
    background: color-mix(in srgb, var(--card-background) 92%, transparent);
    color: var(--text-secondary);
    font-size: 0.75rem;
    line-height: 1.4;
    cursor: pointer;
    opacity: 0.85;
    transition:
      opacity 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }

  #article .code-block-wrap:hover .code-copy-btn,
  #article .code-copy-btn:hover,
  #article .code-copy-btn:focus-visible {
    opacity: 1;
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
  }

  #article .code-copy-btn.is-copied {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
  }

  #article .code-copy-btn.is-copy-failed {
    color: #b45309;
    border-color: color-mix(in srgb, #b45309 40%, var(--border));
  }

  @media (max-width: 640px) {
    #article .code-copy-btn {
      padding: 0.25rem 0.5rem;
    }
  }
</style>
