---
import "@/styles/feed.css";
import Layout from "@/layouts/Layout.astro";
import HomeFeed from "@/components/HomeFeed.astro";
import { SITE } from "@/config";
import type { HomeFeedItem } from "@/utils/postUtils";

interface Props {
  items: HomeFeedItem[];
  nextPage?: number | null;
  page?: number;
  robots?: string;
}

const { items, nextPage = null, page, robots } = Astro.props;
const feedHeading =
  page !== undefined && page >= 2 ? `最近记录 · 第 ${page} 页` : "最近记录";
---

<Layout title={SITE.title} description={SITE.description} robots={robots}>
  <h1 class="feed-page-title">{feedHeading}</h1>
  <HomeFeed items={items} nextPage={nextPage} page={page} />
</Layout>
