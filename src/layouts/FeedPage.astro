---
import "@/styles/feed.css";
import Layout from "@/layouts/Layout.astro";
import HomeFeed from "@/components/HomeFeed.astro";
import { SITE } from "@/config";
import type { HomeFeedItem } from "@/utils/postUtils";

interface Props {
  items: HomeFeedItem[];
  nextPage?: number | null;
}

const { items, nextPage = null } = Astro.props;
---

<Layout title={undefined} description={SITE.description}>
  <HomeFeed items={items} nextPage={nextPage} />
</Layout>
