---
import "@/styles/post.css";
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ArticleExtras from "@/components/ArticleExtras.astro";
import { getEntryDescription, resolveBlogImageRef } from "@/utils/postUtils";
import { siteImageHref } from "@/utils/blogImages";

const { post } = Astro.props;
const { title, date, updated, cover, slug } = post.data;

const coverSrc = (() => {
  const path = resolveBlogImageRef(cover, slug);
  return path ? siteImageHref(path) : undefined;
})();

const { Content } = await render(post);
const body = post.body ?? "";
---

<Layout
  title={title}
  description={getEntryDescription(post)}
  pubDatetime={date}
  modDatetime={updated}
>
  <ArticleExtras body={body} hasCover={Boolean(coverSrc)} />
  <article id="article">
    <h1>{title}</h1>

    {
      coverSrc && (
        <img
          id="post-cover"
          src={coverSrc}
          alt={`${title} — 封面`}
          fetchpriority="high"
          decoding="async"
        />
      )
    }

    <div class="post-content">
      <Content />
    </div>
  </article>
</Layout>
