---
import "@/styles/post.css";
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import ArticleExtras from "@/components/ArticleExtras.astro";
import {
  getEntryDescription,
  resolveBlogImageRef,
  type PostEntry,
  type PostNavLink,
} from "@/utils/postUtils";
import { siteImageHref } from "@/utils/blogImages";

export interface Props {
  post: PostEntry;
  prev: PostNavLink | null;
  next: PostNavLink | null;
}

const { post, prev, next } = Astro.props;
const { title, date, updated, banner, slug } = post.data;

const bannerSrc = (() => {
  const path = resolveBlogImageRef(banner, slug);
  return path ? siteImageHref(path) : undefined;
})();

const { Content } = await render(post);
const body = post.body ?? "";
---

<Layout
  title={title}
  description={getEntryDescription(post)}
  pubDatetime={date}
  modDatetime={updated}
  {...bannerSrc ? { ogImage: bannerSrc } : {}}
>
  <ArticleExtras body={body} />
  <article id="article">
    <h1>{title}</h1>

    {
      bannerSrc && (
        <img
          id="post-banner"
          src={bannerSrc}
          alt={`${title} — 横幅`}
          fetchpriority="high"
          decoding="async"
        />
      )
    }

    <div class="post-content">
      <Content />
    </div>
  </article>

  {
    (prev || next) && (
      <nav aria-label="文章导航">
        {prev && (
          <a href={prev.path}>
            <span aria-hidden="true">←</span>
            <span>{prev.title}</span>
          </a>
        )}
        {next && (
          <a href={next.path} class="nav-next">
            <span>{next.title}</span>
            <span aria-hidden="true">→</span>
          </a>
        )}
      </nav>
    )
  }
</Layout>
