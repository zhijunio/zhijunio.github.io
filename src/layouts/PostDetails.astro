---
/**
 * 文章详情布局
 *
 * @fileoverview 渲染单篇文章：标题、元数据、正文（Content）、前后篇导航、标签列表，以及按 frontmatter 控制的评论/数学公式等功能。canonical 等元信息由本布局传给 Layout。
 */
import { render } from "astro:content";
import type { BlogLikeEntry } from "@/utils/contentCollections";
import { ArticleTime } from "@/utils/articleTime";
import Layout from "@/layouts/Layout.astro";
import Tag from "@/components/Tag.astro";
import ShareButtons from "@/components/ShareButtons.astro";
import Photosuite from "@/components/Photosuite.astro";
import ArticleToc from "@/components/ArticleToc.astro";
import { PostUtils, trimUrlSegment } from "@/utils/postUtils";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import IconTag from "@/assets/icons/IconTag.svg";
import { CDN_KATEX_STYLESHEET, SITE } from "@/config";
import { siteImageHref } from "@/utils/blogImages";

export interface Props {
  post: BlogLikeEntry;
  posts: BlogLikeEntry[];
}

const { post, posts } = Astro.props;

// 解构文章元数据
const {
  title,
  author,
  canonicalURL,
  date,
  updated,
  tags,
  math,
  comments,
  description: postDescription,
  banner: bannerRaw,
} = post.data;

const imageDirName = PostUtils.getPostImageDirName(
  post.id,
  post.filePath,
  date,
  post.data.timezone,
  post.data.slug ?? null,
  post.collection
);
const bannerPath = PostUtils.resolveBlogImageRef(bannerRaw, imageDirName);
const faviconPath = PostUtils.resolveArticleListFaviconPath(
  post.data.favicon,
  post.data.categories
);
const hasBanner = Boolean(bannerRaw?.trim());

/** 解析 banner：`astro dev` 根相对；生产 `/images/...` 走 CDN（与 Photosuite） */
const bannerSrc = bannerPath
  ? PostUtils.isHttpUrl(bannerPath)
    ? bannerPath
    : siteImageHref(bannerPath.startsWith("/") ? bannerPath : `/${bannerPath}`)
  : undefined;

/** OG / JSON-LD：优先横幅图；否则若 `favicon` 为文章配图类 `/images/...`（非列表小图标路径）则用其作分享图 */
let articleOgImage: string | undefined;
if (bannerPath) {
  articleOgImage = bannerSrc;
} else if (faviconPath && /^\/images\//.test(faviconPath)) {
  articleOgImage = siteImageHref(faviconPath);
}
let ogImageAltForLayout: string | undefined;
if (articleOgImage) {
  ogImageAltForLayout = hasBanner ? `${title} — 横幅` : `${title} — 列表图标`;
}

const bannerAltText = `${title} — 横幅`;

// 渲染文章内容
const { Content } = await render(post);
const hasInlineImages = /!\[[\s\S]*?\]\([^)]+\)|<img\s/i.test(post.body ?? "");

/** 文章描述：优先 frontmatter description，否则从正文提取（与 RSS 摘要逻辑一致，不含 banner） */
const fullDescription =
  postDescription?.trim() || PostUtils.getDescription(post.body ?? "");
const plainText = (post.body ?? "")
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/`[^`]*`/g, " ")
  .replace(/!\[[^\]]*]\([^)]+\)/g, " ")
  .replace(/\[[^\]]*]\([^)]+\)/g, " ")
  .replace(/<[^>]+>/g, " ")
  .replace(/[#>*_\-\n\r]/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const latinWordCount = (
  plainText.match(/[A-Za-z0-9]+(?:['' -][A-Za-z0-9]+)*/g) || []
).length;
const cjkCharCount = (plainText.match(/[\u3400-\u9FFF]/g) || []).length;
const estimatedWordCount = latinWordCount + cjkCharCount;
const readingMinutes = Math.max(1, Math.ceil(estimatedWordCount / 300));

/** 标题区发布/更新时间（与列表卡片同一套语义，详情页固定绝对日期） */
const headerTime = ArticleTime.forDetailHeader(
  date,
  updated,
  post.data.timezone
);

const breadcrumbItems = [
  { name: "首页", item: SITE.website },
  { name: "博客", item: new URL("/posts", SITE.website).toString() },
  { name: title, item: canonicalHrefPlaceholder() },
];

function canonicalHrefPlaceholder() {
  return "";
}

const layoutProps = {
  title,
  author,
  description: fullDescription,
  tags,
  pubDatetime: date,
  modDatetime: updated,
  canonicalURL,
  ...(articleOgImage ? { ogImage: articleOgImage } : {}),
  ...(ogImageAltForLayout ? { ogImageAlt: ogImageAltForLayout } : {}),
};

/* ========== Prev/Next Posts ========== */
const allPosts = posts.map(
  ({ data: { title, date, timezone, slug }, id, filePath, collection }) => ({
    path: PostUtils.getPath(
      id,
      filePath,
      true,
      date,
      timezone,
      slug,
      collection
    ),
    title,
  })
);

const currentPostPath = PostUtils.getPath(
  post.id,
  post.filePath,
  true,
  post.data.date,
  post.data.timezone,
  post.data.slug,
  post.collection
);

const canonicalHref =
  canonicalURL != null
    ? String(canonicalURL)
    : new URL(currentPostPath, SITE.website).toString();
breadcrumbItems[breadcrumbItems.length - 1].item = canonicalHref;
const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: item.item,
  })),
};

const relatedPostLimit = 6;
const scoredRelatedPosts = posts
  .filter(candidate => candidate.id !== post.id)
  .map(candidate => {
    const sharedTags = candidate.data.tags.filter(tag =>
      tags.includes(tag)
    ).length;
    const score = sharedTags * 2;

    return {
      post: candidate,
      score,
      path: PostUtils.getPath(
        candidate.id,
        candidate.filePath,
        true,
        candidate.data.date,
        candidate.data.timezone,
        candidate.data.slug,
        candidate.collection
      ),
    };
  })
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;

    return (
      new Date(b.post.data.updated ?? b.post.data.date).getTime() -
      new Date(a.post.data.updated ?? a.post.data.date).getTime()
    );
  });

const relatedPosts = [
  ...scoredRelatedPosts.filter(item => item.score > 0),
  ...scoredRelatedPosts.filter(item => item.score === 0),
].slice(0, relatedPostLimit);

const shareText = `${title} | ${SITE.title}`;

const currentPostIndex = allPosts.findIndex(a => a.path === currentPostPath);

const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;

/** 预加载样式转正样式用，避免 TS 把 onload 属性内容当代码解析 */
const linkPreloadOnLoad = "this.onload=null;this.rel='stylesheet'";
---

<Layout {...layoutProps}>
  {hasInlineImages && <Photosuite />}
  {
    bannerSrc && (
      <link
        slot="head"
        rel="preload"
        as="image"
        href={bannerSrc}
        fetchpriority="high"
      />
    )
  }
  {
    tags.map((tag: string) => (
      <meta slot="head" property="article:tag" content={tag} />
    ))
  }
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbStructuredData)}
  />
  <!-- KaTeX 数学公式样式（仅文章详情且启用公式时加载） -->
  {
    math && (
      <link
        slot="head"
        rel="preload"
        href={CDN_KATEX_STYLESHEET}
        as="style"
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
        onload={linkPreloadOnLoad}
      />
    )
  }
  {
    math && (
      <noscript slot="head">
        <link
          rel="stylesheet"
          href={CDN_KATEX_STYLESHEET}
          crossorigin="anonymous"
          referrerpolicy="no-referrer"
        />
      </noscript>
    )
  }

  <article id="article" class="post w-full min-w-0" data-pagefind-body>
    <header class="w-full">
      <div
        class="mb-4 text-sm text-muted [&_a]:text-muted [&_a:hover]:text-accent"
        aria-label="面包屑导航"
      >
        <a href="/">首页</a>
        <span class="mx-1.5 opacity-60" aria-hidden="true">/</span>
        <a href="/posts">博客</a>
      </div>

      <section class="mb-6">
        <h1
          class="mt-0 mb-3 text-center text-[clamp(1.375rem,3.25vw,1.75rem)] leading-tight font-semibold text-foreground"
        >
          {title}
        </h1>
        <div
          class="post-meta flex flex-wrap items-center justify-center gap-x-2 gap-y-2 text-center text-sm text-muted"
        >
          <span class="whitespace-nowrap tabular-nums"
            >{readingMinutes} 分钟阅读</span
          >
          <span class="opacity-50" aria-hidden="true">·</span>
          <div
            class="inline-flex min-w-0 items-baseline gap-0.5"
            title={headerTime.titleAttr}
          >
            <time
              class="text-sm font-normal tracking-wide text-muted tabular-nums"
              datetime={headerTime.iso}
              data-date-format="absolute"
            >
              {headerTime.display}
            </time>
          </div>
        </div>
      </section>
    </header>

    {
      bannerSrc && (
        <img
          id="post-banner"
          class="mx-auto my-6 block h-auto w-full max-w-[min(100%,56rem)] rounded-lg"
          src={bannerSrc}
          alt={bannerAltText}
          fetchpriority="high"
          decoding="async"
          sizes="(max-width: 768px) 100vw, min(100%, 56rem)"
        />
      )
    }

    <div
      class="post-layout flex min-w-0 flex-col gap-5 lg:flex-row lg:items-start"
    >
      <div class="post-content min-w-0 flex-1 pb-4">
        <Content />
      </div>
      <ArticleToc />
    </div>
  </article>

  <!-- 正文以下：共用一条顶部分割线，子块之间只用间距，避免多条「横线」叠在一起 -->
  <div
    class="post-footer-stack clear-both w-full min-w-0 space-y-5 border-t border-border/80 pt-6 max-sm:space-y-5 max-sm:pt-5"
  >
    <!-- 标签 + 分享 -->
    <div class="flex w-full min-w-0 flex-col items-center gap-3 sm:flex-row sm:items-center sm:justify-between">
      {
        tags.length > 0 && (
          <ul class="m-0 flex list-none flex-wrap justify-center gap-2 p-0" role="list">
            {tags.map((tag: string) => (
              <Tag tag={trimUrlSegment(tag)} tagName={tag} />
            ))}
          </ul>
        )
      }
      <ShareButtons url={canonicalHref} title={shareText} description={fullDescription} />
    </div>

    <!-- 文章导航 -->
    {(prevPost || nextPost) && (
      <nav class="post-nav w-full min-w-0" aria-label="文章导航">
        <div class="flex flex-col gap-2 sm:flex-row sm:justify-between">
          {
            prevPost && (
              <a
                href={prevPost.path}
                class="post-nav-link flex items-center gap-1.5 text-sm text-muted no-underline transition-colors hover:text-accent"
              >
                <IconChevronLeft class="h-4 w-4 shrink-0" />
                <span>{prevPost.title}</span>
              </a>
            )
          }
          {
            nextPost && (
              <a
                href={nextPost.path}
                class="post-nav-link flex items-center gap-1.5 text-sm text-muted no-underline transition-colors hover:text-accent sm:text-right sm:justify-end"
              >
                <span>{nextPost.title}</span>
                <IconChevronRight class="h-4 w-4 shrink-0" />
              </a>
            )
          }
        </div>
      </nav>
    )}

    <!-- 相关文章 -->
    {
      relatedPosts.length > 0 && (
        <section class="related-section w-full min-w-0" aria-label="相关文章">
          <h3 class="m-0 mb-2 text-base font-medium text-foreground">相关文章</h3>
          <ul class="related-list m-0 list-none divide-y divide-border/50 p-0" role="list">
            {relatedPosts.map(({ post: relatedPost, path }) => (
              <li>
                <a
                  href={path}
                  class="related-link block py-1.5 text-sm text-muted no-underline transition-colors hover:text-accent"
                >
                  {relatedPost.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>

  <!-- 评论容器：与主栏同宽（不用 reading-wrap 窄栏） -->
  {
    comments && SITE.giscus.enabled && (
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo="zhijunio/zhijunio.github.io"
        data-repo-id="R_kgDOIwiKuA"
        data-category="Announcements"
        data-category-id="DIC_kwDOIwiKuM4C6yVl"
        data-mapping="title"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="zh-CN"
        data-loading="lazy"
        crossorigin="anonymous"
        async
      />
    )
  }
  <style is:global>
    /**
     * 正文 + 目录（≥lg）：TOC fixed 定位到页面右侧空白区。
     * 移动端隐藏 TOC。
     */
    #article-toc {
      display: none;
    }

    @media (min-width: 1024px) {
      #article-toc {
        display: block;
        position: fixed;
        right: 2rem;
        top: 6rem;
        width: 15rem;
        max-height: calc(100vh - 10rem);
        overflow-y: auto;
        margin: 0;
      }
    }

    .post-content :where(h2, h3, h4) {
      scroll-margin-top: var(--site-header-sticky-offset);
    }

    #main-content .post-content {
      line-height: 1.8;
    }

    #main-content .post-content img {
      border-radius: 8px;
    }

    /** 文章导航：无边框简约样式 */
    .post-nav-link {
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  </style>

  <script is:inline data-astro-rerun>
    function onPageReady() {
      window.scrollTo({ left: 0, top: 0, behavior: "instant" });
    }
    if (window._postDetailsAfterSwapHandler) {
      document.removeEventListener(
        "astro:after-swap",
        window._postDetailsAfterSwapHandler
      );
    }
    window._postDetailsAfterSwapHandler = onPageReady;
    document.addEventListener(
      "astro:after-swap",
      window._postDetailsAfterSwapHandler
    );
    onPageReady();
  </script>
</Layout>
