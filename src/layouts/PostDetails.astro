---
/**
 * 文章详情布局
 *
 * @fileoverview 渲染单篇文章：标题、元数据、正文（Content）、前后篇导航、标签列表，以及按 frontmatter 控制的评论/数学公式等功能。canonical 等元信息由本布局传给 Layout。
 */
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Photosuite from "@/components/Photosuite.astro";
import ArticleToc from "@/components/ArticleToc.astro";
import { PostUtils, type BlogLikeEntry } from "@/utils/postUtils";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { CDN_KATEX_STYLESHEET, SITE } from "@/config";
import { siteImageHref } from "@/utils/blogImages";

export interface Props {
  post: BlogLikeEntry;
  posts: BlogLikeEntry[];
}

const { post, posts } = Astro.props;

// 解构文章元数据
const {
  title,
  author,
  canonicalURL,
  date,
  updated,
  tags,
  math,
  comments,
  description: postDescription,
  banner: bannerRaw,
} = post.data;

const imageDirName = PostUtils.getPostImageDirName(
  post.id,
  post.filePath,
  date,
  post.data.timezone,
  post.data.slug ?? null,
  post.collection
);
const bannerPath = PostUtils.resolveBlogImageRef(bannerRaw, imageDirName);

/** 解析 banner：`astro dev` 根相对；生产 `/images/...` 走 CDN（与 Photosuite） */
const bannerSrc = bannerPath
  ? PostUtils.isHttpUrl(bannerPath)
    ? bannerPath
    : siteImageHref(bannerPath.startsWith("/") ? bannerPath : `/${bannerPath}`)
  : undefined;

/** OG / JSON-LD：有 banner 时用横幅图 */
let articleOgImage: string | undefined;
if (bannerPath) {
  articleOgImage = bannerSrc;
}
let ogImageAltForLayout: string | undefined;
if (articleOgImage) {
  ogImageAltForLayout = `${title} — 横幅`;
}

const bannerAltText = `${title} — 横幅`;

// 渲染文章内容
const { Content } = await render(post);
const hasInlineImages = /!\[[\s\S]*?\]\([^)]+\)|<img\s/i.test(post.body ?? "");

/** 文章描述：优先 frontmatter description，否则从正文提取（与 RSS 摘要逻辑一致，不含 banner） */
const fullDescription =
  postDescription?.trim() || PostUtils.getDescription(post.body ?? "");

const layoutProps = {
  title,
  author,
  description: fullDescription,
  tags,
  pubDatetime: date,
  modDatetime: updated,
  canonicalURL,
  ...(articleOgImage ? { ogImage: articleOgImage } : {}),
  ...(ogImageAltForLayout ? { ogImageAlt: ogImageAltForLayout } : {}),
};

/* ========== Prev/Next Posts ========== */
const allPosts = posts.map(
  ({ data: { title, date, timezone, slug }, id, filePath, collection }) => ({
    path: PostUtils.getPath(
      id,
      filePath,
      true,
      date,
      timezone,
      slug,
      collection
    ),
    title,
  })
);

const currentPostPath = PostUtils.getPath(
  post.id,
  post.filePath,
  true,
  post.data.date,
  post.data.timezone,
  post.data.slug,
  post.collection
);

const currentPostIndex = allPosts.findIndex(a => a.path === currentPostPath);

const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;

/** 预加载样式转正样式用，避免 TS 把 onload 属性内容当代码解析 */
const linkPreloadOnLoad = "this.onload=null;this.rel='stylesheet'";

const giscusThemeLight = "https://giscus.app/themes/light.css";
const giscusThemeDark = "https://giscus.app/themes/dark.css";
---

<Layout {...layoutProps}>
  {hasInlineImages && <Photosuite />}
  {
    bannerSrc && (
      <link
        slot="head"
        rel="preload"
        as="image"
        href={bannerSrc}
        fetchpriority="high"
      />
    )
  }
  {
    tags.map((tag: string) => (
      <meta slot="head" property="article:tag" content={tag} />
    ))
  }
  <!-- KaTeX 数学公式样式（仅文章详情且启用公式时加载） -->
  {
    math && (
      <link
        slot="head"
        rel="preload"
        href={CDN_KATEX_STYLESHEET}
        as="style"
        crossorigin="anonymous"
        referrerpolicy="no-referrer"
        onload={linkPreloadOnLoad}
      />
    )
  }
  {
    math && (
      <noscript slot="head">
        <link
          rel="stylesheet"
          href={CDN_KATEX_STYLESHEET}
          crossorigin="anonymous"
          referrerpolicy="no-referrer"
        />
      </noscript>
    )
  }

  <article id="article" data-pagefind-body>
    <header>
      <h1>{title}</h1>
    </header>

    {
      bannerSrc && (
        <img
          id="post-banner"
          src={bannerSrc}
          alt={bannerAltText}
          fetchpriority="high"
          decoding="async"
          sizes="(max-width: 768px) 100vw, min(100%, 60rem)"
        />
      )
    }

    <div class="post-content">
      <Content />
    </div>
  </article>

  <ArticleToc />

  {
    tags.length > 0 && (
      <ul role="list" aria-label="文章标签">
        {tags.map((tag: string) => (
          <li>
            <a href={`/search?q=${encodeURIComponent(tag)}`}>{tag}</a>
          </li>
        ))}
      </ul>
    )
  }

  {
    (prevPost || nextPost) && (
      <nav aria-label="文章导航">
        {prevPost && (
          <a href={prevPost.path}>
            <IconChevronLeft />
            <span>{prevPost.title}</span>
          </a>
        )}
        {nextPost && (
          <a href={nextPost.path} data-dir="next">
            <span>{nextPost.title}</span>
            <IconChevronRight />
          </a>
        )}
      </nav>
    )
  }

  {
    comments && SITE.giscus.enabled && (
      <section aria-label="评论">
        <script
          is:inline
          src="https://giscus.app/client.js"
          data-repo="zhijunio/zhijunio.github.io"
          data-repo-id="R_kgDOIwiKuA"
          data-category="Announcements"
          data-category-id="DIC_kwDOIwiKuM4C6yVl"
          data-mapping="title"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme={giscusThemeLight}
          data-lang="zh-CN"
          data-loading="lazy"
          crossorigin="anonymous"
          async
        />
        <meta name="giscus-theme-light" content={giscusThemeLight} />
        <meta name="giscus-theme-dark" content={giscusThemeDark} />
        <script is:inline data-astro-rerun>
          function getGiscusThemeUrl() {
            const isDark =
              document.documentElement.getAttribute("data-theme") === "dark";
            const meta = document.querySelector(
              isDark
                ? 'meta[name="giscus-theme-dark"]'
                : 'meta[name="giscus-theme-light"]'
            );
            return meta?.getAttribute("content") ?? "";
          }

          function updateGiscusTheme() {
            const iframe = document.querySelector("iframe.giscus-frame");
            if (!iframe?.contentWindow) return;
            iframe.contentWindow.postMessage(
              { giscus: { setConfig: { theme: getGiscusThemeUrl() } } },
              "https://giscus.app"
            );
          }

          window.addEventListener("load", updateGiscusTheme);
          document.addEventListener("themechange", updateGiscusTheme);
          document.addEventListener("astro:page-load", updateGiscusTheme);
        </script>
      </section>
    )
  }

  <style is:global>
    #article {
      width: 100%;
      min-width: 0;
    }

    #article > header {
      margin-bottom: 0.25rem;
    }

    #article h1 {
      margin: 0 0 2.25rem;
      font-size: clamp(1.2rem, 2.6vw, 1.5rem);
      line-height: 1.35;
      font-weight: 600;
      text-align: center;
      text-wrap: balance;
    }

    #post-banner {
      margin: 0.25rem auto 2.25rem;
      border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
      border-radius: var(--radius);
      background: var(--card-background);
    }

    #article .post-content {
      min-width: 0;
      padding: 0.15rem 0 1rem;
      line-height: 1.8;
    }

    #article .post-content > :first-child {
      margin-top: 0;
    }

    #main-content .post-content :where(h2, h3, h4) {
      scroll-margin-top: var(--site-header-sticky-offset);
    }

    #main-content .post-content :is(img, picture, video) {
      border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
      border-radius: var(--radius);
      background: var(--card-background);
    }

    #main-content .post-content figcaption {
      font-size: 0.8125rem;
      line-height: 1.5;
    }

    #main-content ul[aria-label="文章标签"] {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.65rem;
      margin: 2rem 0 0;
      padding: 0;
      list-style: none;
      font-size: 0.8125rem;
      line-height: 1.5;
    }

    #main-content ul[aria-label="文章标签"] a {
      color: var(--text-secondary);
      text-decoration: none;
    }

    #main-content ul[aria-label="文章标签"] a:hover {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 0.12em;
    }

    #main-content nav[aria-label="文章导航"] {
      clear: both;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 2rem;
      padding-top: 1.25rem;
      border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    }

    @media (min-width: 640px) {
      #main-content nav[aria-label="文章导航"] {
        flex-direction: row;
        justify-content: space-between;
      }

      #main-content nav[aria-label="文章导航"] a[data-dir="next"] {
        justify-content: flex-end;
        text-align: right;
      }
    }

    #main-content nav[aria-label="文章导航"] a {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      max-width: 100%;
      overflow: hidden;
      font-size: 0.875rem;
      color: var(--text-secondary);
      text-decoration: none;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    #main-content nav[aria-label="文章导航"] a:hover {
      color: var(--accent);
      text-decoration: none;
    }

    #main-content nav[aria-label="文章导航"] svg {
      width: 1rem;
      height: 1rem;
      flex-shrink: 0;
    }

    #main-content section[aria-label="评论"] {
      margin-top: 2rem;
      padding-top: 1.25rem;
      border-top: 1px solid color-mix(in srgb, var(--border) 65%, transparent);
    }

    #main-content section[aria-label="评论"] .giscus,
    #main-content section[aria-label="评论"] iframe.giscus-frame {
      width: 100%;
    }
  </style>

  <script is:inline data-astro-rerun>
    function onPageReady() {
      window.scrollTo({ left: 0, top: 0, behavior: "instant" });
    }
    if (window._postDetailsAfterSwapHandler) {
      document.removeEventListener(
        "astro:after-swap",
        window._postDetailsAfterSwapHandler
      );
    }
    window._postDetailsAfterSwapHandler = onPageReady;
    document.addEventListener(
      "astro:after-swap",
      window._postDetailsAfterSwapHandler
    );
    onPageReady();
  </script>
</Layout>
