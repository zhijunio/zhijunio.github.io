---
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Photosuite from "@/components/Photosuite.astro";
import MermaidLoader from "@/components/MermaidLoader.astro";
import CodeCopyButton from "@/components/CodeCopyButton.astro";
import {
  getDescription,
  getPostUrl,
  isHttpUrl,
  resolveBlogImageRef,
  type BlogLikeEntry,
} from "@/utils/postUtils";
import { siteImageHref } from "@/utils/blogImages";

export interface Props {
  post: BlogLikeEntry;
  posts: BlogLikeEntry[];
}

const { post, posts } = Astro.props;
const { title, date, updated, description: postDescription, banner, slug } =
  post.data;

const bannerPath = resolveBlogImageRef(banner, slug);
const bannerSrc = bannerPath
  ? isHttpUrl(bannerPath)
    ? bannerPath
    : siteImageHref(bannerPath.startsWith("/") ? bannerPath : `/${bannerPath}`)
  : undefined;

const { Content } = await render(post);
const body = post.body ?? "";
const hasInlineImages = /!\[[\s\S]*?\]\([^)]+\)|<img\s/i.test(body);
const needsMermaid = /```mermaid\b/i.test(body);
const needsCodeCopy = /```[\s\S]*?```/.test(body);

const fullDescription =
  postDescription?.trim() || getDescription(body);

const navPosts = posts.map(p => ({
  path: getPostUrl(p.data.slug, p.collection),
  title: p.data.title,
}));
const currentPath = getPostUrl(slug, post.collection);
const idx = navPosts.findIndex(a => a.path === currentPath);
const prevPost = idx > 0 ? navPosts[idx - 1] : null;
const nextPost = idx >= 0 && idx < navPosts.length - 1 ? navPosts[idx + 1] : null;
---

<Layout
  title={title}
  description={fullDescription}
  pubDatetime={date}
  modDatetime={updated}
  {...bannerSrc ? { ogImage: bannerSrc } : {}}
>
  {hasInlineImages && <Photosuite />}
  {needsMermaid && <MermaidLoader />}
  {needsCodeCopy && <CodeCopyButton />}
  <article id="article">
    <h1>{title}</h1>

    {
      bannerSrc && (
        <img
          id="post-banner"
          src={bannerSrc}
          alt={`${title} — 横幅`}
          fetchpriority="high"
          decoding="async"
        />
      )
    }

    <div class="post-content">
      <Content />
    </div>
  </article>

  {
    (prevPost || nextPost) && (
      <nav aria-label="文章导航">
        {prevPost && (
          <a href={prevPost.path}>
            <span aria-hidden="true">←</span>
            <span>{prevPost.title}</span>
          </a>
        )}
        {nextPost && (
          <a href={nextPost.path} class="nav-next">
            <span>{nextPost.title}</span>
            <span aria-hidden="true">→</span>
          </a>
        )}
      </nav>
    )
  }

  <style is:global>
    #article h1 {
      margin: 0 0 2rem;
      font-size: clamp(1.2rem, 2.6vw, 1.5rem);
      line-height: 1.35;
      font-weight: 600;
      text-align: center;
      text-wrap: balance;
    }

    #post-banner {
      display: block;
      max-width: 100%;
      margin: 0 auto 2rem;
      border: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
      border-radius: var(--radius);
    }

    #article .post-content {
      line-height: 1.8;
    }

    #main-content .post-content :where(h2, h3, h4) {
      scroll-margin-top: var(--site-header-sticky-offset);
    }

    #main-content nav[aria-label="文章导航"] {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 2rem;
      padding-top: 1.25rem;
      border-top: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    }

    @media (min-width: 640px) {
      #main-content nav[aria-label="文章导航"] {
        flex-direction: row;
        justify-content: space-between;
      }

      #main-content nav[aria-label="文章导航"] .nav-next {
        margin-left: auto;
        text-align: right;
      }
    }

    #main-content nav[aria-label="文章导航"] a {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      max-width: 100%;
      overflow: hidden;
      font-size: 0.875rem;
      color: var(--text-secondary);
      text-decoration: none;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    #main-content nav[aria-label="文章导航"] a:hover {
      color: var(--accent);
    }
  </style>
</Layout>
