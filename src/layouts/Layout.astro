---
import { CDN_ORIGIN, SITE, formatDocumentTitle } from "@/config";
import {
  devLocalImageRef,
  publicImageAbsoluteUrl,
} from "@/utils/blogImages";
import "@/styles/global.css";
import "@/styles/chrome.css";
import Header from "@/components/Header.astro";
import BackToTop from "@/components/BackToTop.astro";

export interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
  robots?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
}

const pathname = Astro.url.pathname.replace(/\.html?$/, "") || "/";

const {
  title: titleProp,
  description: descriptionProp,
  canonicalURL = new URL(pathname, Astro.url),
  robots,
  pubDatetime,
  modDatetime,
} = Astro.props;

const rawTitle = titleProp?.trim() ?? "";
const isHomePage = pathname === "/";
const headline = rawTitle || SITE.title;
const documentTitle = isHomePage
  ? SITE.title
  : formatDocumentTitle(rawTitle);
const fullDescription = descriptionProp?.trim() || SITE.description;
const robotsContent = robots?.trim() || "index,follow";
const pageUrl = String(canonicalURL);
const isArticlePage = Boolean(pubDatetime);
const ogType = isArticlePage ? "article" : "website";
const ogLocale = SITE.lang.replace("-", "_");

const siteOrigin = import.meta.env.DEV
  ? Astro.url.origin
  : (Astro.site?.origin ?? Astro.url.origin);
const ogImageRef = devLocalImageRef(SITE.defaultOgImage);
const socialImageURL = /^https?:\/\//i.test(ogImageRef)
  ? ogImageRef
  : publicImageAbsoluteUrl(SITE.defaultOgImage, siteOrigin);

const umamiEnabled =
  import.meta.env.PROD &&
  SITE.umami.enabled &&
  Boolean(SITE.umami.websiteId.trim()) &&
  Boolean(SITE.umami.scriptUrl.trim());

const structuredData = isArticlePage
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline,
      description: fullDescription,
      url: pageUrl,
      mainEntityOfPage: pageUrl,
      image: socialImageURL,
      datePublished: pubDatetime?.toISOString(),
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
      author: [{ "@type": "Person", name: SITE.author }],
      publisher: {
        "@type": "Organization",
        name: SITE.title,
        url: SITE.website,
      },
    }
  : isHomePage
    ? {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: SITE.title,
        url: SITE.website,
        description: fullDescription,
        inLanguage: SITE.lang,
      }
    : null;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="preconnect" href={CDN_ORIGIN} crossorigin />

    <title>{documentTitle}</title>
    <meta name="description" content={fullDescription} />
    <meta name="author" content={SITE.author} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#fcfdff" />

    <meta property="og:title" content={headline} />
    <meta property="og:description" content={fullDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:alt" content={SITE.title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:type" content={ogType} />

    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    {
      structuredData && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(structuredData)}
        />
      )
    }

    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    {
      SITE.googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={SITE.googleSiteVerification}
        />
      )
    }
    {
      SITE.bingSiteVerification && (
        <meta name="msvalidate.01" content={SITE.bingSiteVerification} />
      )
    }

  </head>
  <body>
    <a class="skip-link" href="#main-content">跳转到主要内容</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <BackToTop />
    {
      umamiEnabled && (
        <script
          is:inline
          define:vars={{
            websiteId: SITE.umami.websiteId,
            scriptUrl: SITE.umami.scriptUrl,
          }}
        >
          (function () {
            let done = false;
            function load() {
              if (done) return;
              done = true;
              const s = document.createElement("script");
              s.src = scriptUrl;
              s.setAttribute("data-website-id", websiteId);
              s.defer = true;
              document.head.appendChild(s);
            }
            ["click", "keydown", "touchstart", "scroll"].forEach(ev =>
              window.addEventListener(ev, load, { once: true, passive: true })
            );
          })();
        </script>
      )
    }
  </body>
</html>
