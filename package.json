{
  "name": "astro-zhijunio",
  "type": "module",
  "version": "1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "dev:clean": "rm -rf node_modules/.vite node_modules/.astro && astro dev --host",
    "build": "astro build && node scripts/prune-dist-images.mjs",
    "ci": "pnpm run lint && pnpm run format:check && pnpm run check && pnpm run build",
    "check": "astro check",
    "format:check": "pnpm exec prettier --check .",
    "format": "pnpm exec prettier --write .",
    "lint": "eslint .",
    "convert-to-webp": "node scripts/convert-to-webp.mjs",
    "images:sync": "rclone sync public/favicon.ico r2:cos/favicon.ico -P && rclone sync public/og.webp r2:cos/og.webp -P && rclone sync public/images r2:cos/images -P",
    "images:publish": "node scripts/convert-to-webp.mjs && pnpm run images:sync"
  },
  "dependencies": {
    "@astrojs/rss": "4.0.19",
    "astro": "^7.0.0",
    "mermaid": "^11.12.3",
    "photosuite": "0.4.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-wrap-all": "^1.1.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.2",
    "eslint": "^10.0.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^17.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.33.1"
  }
}
