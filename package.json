{
  "name": "astro-zhijunio",
  "type": "module",
  "version": "1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro check && astro build",
    "preview": "astro preview --host --allowed-hosts=blog.zhijun.io",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "pnpm exec prettier --check .",
    "format": "pnpm exec prettier --write .",
    "lint": "eslint .",
    "convert-to-webp": "node scripts/convert-to-webp.mjs",
    "images:sync": "rclone sync public/favicon.ico r2:cos/favicon.ico -P && rclone sync public/og.webp r2:cos/og.webp -P && rclone sync public/images r2:cos/images -P",
    "images:publish": "node scripts/convert-to-webp.mjs && pnpm run images:sync",
    "md:check": "pnpm dlx markdownlint-cli2 \"./content/tech/**/*.md\" \"./content/weekly/**/*.md\" \"./content/about.md\" --config package.json --configPointer /markdownlint-cli2/config",
    "md:fix": "pnpm dlx markdownlint-cli2 --fix \"./content/tech/**/*.md\" \"./content/weekly/**/*.md\" \"./content/about.md\" --config package.json --configPointer /markdownlint-cli2/config"
  },
  "markdownlint-cli2": {
    "config": {
      "default": true,
      "MD003": {
        "style": "atx"
      },
      "MD013": false,
      "MD024": {
        "siblings_only": true
      },
      "MD025": {
        "front_matter_title": ""
      },
      "MD033": false,
      "MD036": false,
      "MD040": false,
      "MD041": false,
      "MD045": false,
      "MD060": false
    }
  },
  "dependencies": {
    "@astrojs/rss": "4.0.18",
    "@tailwindcss/vite": "^4.1.8",
    "astro": "^6.0.0",
    "dayjs": "^1.11.19",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.12.3",
    "photosuite": "0.2.1-beta",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-wrap-all": "^1.1.0",
    "tailwindcss": "^4.1.8",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.2",
    "eslint": "^10.0.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^17.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.34.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.33.1"
  }
}
